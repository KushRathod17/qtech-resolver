# Copy this file to .env and fill in your own values. Never commit .env.
# Replace the password below with your local Postgres password.
# If it contains special characters, URL-encode them (@ becomes %40).
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/qtech_resolver

# Generate a real one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:5173

# Who may SELF-register, comma separated. EMPTY MEANS SELF-REGISTRATION IS OFF —
# that is the safe default. Admins add people on the People page instead.
# The very first account is always allowed, so a fresh install can be bootstrapped.
ALLOWED_SIGNUP_DOMAINS=

# Failed sign-ins allowed per IP / per email before a temporary lockout.
LOGIN_MAX_ATTEMPTS=8
LOGIN_LOCKOUT_SECONDS=900
