# Copy this file to .env and fill in your own values. Never commit .env.
# Replace the password below with your local Postgres password.
# If it contains special characters, URL-encode them (@ becomes %40).
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/qtech_resolver

# Generate a real one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:5173

# The invite code every registration must type in, on BOTH signup paths
# (create a new organization, and join an existing one). Hand it to your team
# out of band — chat, in person, a password manager; not in this repo.
#
# EMPTY MEANS REGISTRATION IS BLOCKED ENTIRELY — that is the safe default, and
# it is deliberate: an unset gate must never read as an open one. Existing
# users can still log in; only new signups are refused.
#
#   python -c "import secrets; print(secrets.token_urlsafe(12))"
INVITE_CODE=

# OPTIONAL extra restriction on top of INVITE_CODE: who may self-JOIN an
# existing organization, by email domain, comma separated. Empty means no
# domain restriction — safe only because INVITE_CODE above is mandatory and
# already blocks registration on its own when unset.
ALLOWED_SIGNUP_DOMAINS=

# Failed sign-ins allowed per IP / per email before a temporary lockout.
LOGIN_MAX_ATTEMPTS=8
LOGIN_LOCKOUT_SECONDS=900

# Object storage for ticket attachments and avatars. Leave all five blank to
# use local disk under backend/uploads/ (fine for local dev). Fill them in to
# point at any S3-compatible bucket instead (Cloudflare R2, AWS S3, Backblaze
# B2, ...) — required in production on a host without a persistent disk. See
# app/storage.py and DEPLOYING.md.
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=auto
